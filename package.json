{
  "name": "focus-agent",
  "version": "1.0.0",
  "description": "AI-Powered Focus & Study Agent Desktop App",
  "main": "out/main/index.js",
  "type": "module",
  "author": "Focus Agent",
  "scripts": {
    "dev": "electron-vite dev --config electron.vite.config.mjs",
    "build": "electron-vite build --config electron.vite.config.mjs",
    "preview": "electron-vite preview --config electron.vite.config.mjs",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "date-fns": "^3.6.0",
    "langchain": "^0.3.0",
    "node-cron": "^3.0.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@rollup/rollup-win32-x64-msvc": "^4.60.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "build": {
    "appId": "com.focusagent.app",
    "productName": "Focus Agent",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "category": "Education",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
